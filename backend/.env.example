# 时空信箱 - 环境变量配置
# Copy to .env and fill in values

# OpenAI API (GPT-4o-mini for emotion analysis, GPT-4o for vision)
OPENAI_API_KEY=sk-your-key-here

# ElevenLabs API (voice cloning)
ELEVENLABS_API_KEY=your-key-here

# Mapbox token (for frontend map tiles)
VITE_MAPBOX_TOKEN=pk.your-token-here

# Server config
DATABASE_URL=sqlite+aiosqlite:///./data/timespace.db
UPLOAD_DIR=./data/uploads
HOST=0.0.0.0
PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
